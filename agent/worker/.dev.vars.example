# Copy to .dev.vars for local real-worker QA. Never commit real values.
SMARTFLOW_WORKER_MODE=local-qa
SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_ANON_KEY=<local-public-anon-key>
GEMINI_API_KEY=<local-secret>
GEMINI_MODEL=gemini-2.5-flash

# GitHub App Slice 1. Register a dedicated local QA App before filling these.
GITHUB_APP_ID=<non-secret-app-id>
GITHUB_CLIENT_ID=<non-secret-client-id>
GITHUB_APP_SLUG=<app-slug>
GITHUB_SETUP_URL=http://127.0.0.1:8787/github/connect/setup
GITHUB_CALLBACK_URL=http://127.0.0.1:8787/github/connect/callback
GITHUB_ALLOWED_ORIGINS=http://localhost:8080,http://127.0.0.1:8080
GITHUB_APP_PRIVATE_KEY=<worker-secret-private-key>
GITHUB_CLIENT_SECRET=<worker-secret-client-secret>
